import { useState } from 'react';
import deleteFamilyDataFunction from '../../../../Functions/Family/DeleteFamilyData';


export function useRemoveFamilyRegister() {
    const [RemoveFamilyRegisterLoading, setLoading] = useState(false);
    const [RemoveFamilyRegisterMessage, setMessage] = useState(null);
    
    const handleRemoveFamilyRegister = async ( id_family ) => {
        setLoading(true);
        setMessage(null);

        try {
            const response = await deleteFamilyDataFunction( id_family );
            //const response = {"status" : 0, "content" : "true"}
            if (response.status === 0) {
                setMessage("Registro deletado com sucesso");
            }
            else {
                setMessage(response.content);
            }

            const timer = setTimeout(() => {
                setMessage('');
            }, 2000);
            setLoading(false);
            return () => clearTimeout(timer);

            
        } catch (err) {
            setMessage(err.content);
        } finally {
            setLoading(false);
        } 
    }

    return { handleRemoveFamilyRegister, RemoveFamilyRegisterLoading, RemoveFamilyRegisterMessage };
}